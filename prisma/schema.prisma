

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  tests         Test[]
  profile       Profile?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}


model Profile {
  userId String @id @default(uuid())
  user User @relation(fields:[userId], references: [id], onDelete: Cascade)

	email String @unique
  username String @unique
  timeJoined DateTime @default(now())

  testsAttempted Int @default(0)
  testsCompleted Int @default(0)

  standard_1 String?
  standard_2 String?
  standard_3 String?
  standardAverage Float @default(0)
  standardTotalTests Int @default(0)
  standardPastTenTests Int[] @default([])

  rapid_1 String?
  rapid_2 String?
  rapid_3 String?
  rapidAverage Float @default(0)
  rapidTotalTests Int @default(0)
  rapidPastTenTests Int[] @default([])

  sprint_1 String?
  sprint_2 String?
  sprint_3 String?
  sprintAverage Float @default(0)
  sprintTotalTests Int @default(0)
  sprintPastTenTests Int[] @default([])

  hard_1 String?
  hard_2 String?
  hard_3 String?
  hardAverage Float @default(0)
  hardTotalTests Int @default(0)
  hardPastTenTests Int[] @default([])

  
}

model Test {
  id String @id @default(uuid())
  score Int
  time DateTime @default(now())
  gameMode String
  userId String?
  user User? @relation(fields:[userId], references: [id] , onDelete: Cascade) 
  problems Problem[]

  @@index([userId])
  @@index([gameMode, score])

}

model Problem {
  id String @id @default(uuid())
  testId String
  test Test @relation(fields:[testId], references: [id] , onDelete: Cascade) 
  orderNumber Int @default(0)
  operation String
  firstNum Float
  secondNum Float
  answer Float
  gameMode String
  statement String
  solveTime Float

  @@index([testId])
}
